<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit</title>
</head>
<body>
    <h1>Edit product: <%=r[0].P_id %></h1>
    <form action="/products/<%=r[0].P_id%>?_method=PUT" method="post">
        <label for="">Name</label>
        <input type="text" name="E_name" id="" value="<%=r[0].P_name%>"> <br>
         <label for="">Price</label>
        <input type="number" name="E_price" id="" value="<%=r[0].P_price%>"> <br>

         <label for="">qty</label>
        <input type="number" name="E_qty" id="" value="<%=r[0].P_qty%>"> <br>

         <label for="">Img Url</label>
        <input type="text" name="E_img" id="" value="<%=r[0].P_img%>"> <br>

         <label for="">Product</label>
        <input type="text" name="E_id" id="" value="<%=r[0].P_id%>"> <br>

        <button type="submit">Edit</button>

    </form>
</body>
</html>